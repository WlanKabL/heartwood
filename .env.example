# Postgres connection string.
DATABASE_URL=postgres://heartwood:heartwood@localhost:5432/heartwood

# GitHub OAuth app credentials (create at https://github.com/settings/developers).
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# Session encryption key — minimum 32 characters, keep secret.
SESSION_SECRET=change-me-to-a-random-string-of-at-least-32-chars

# Public front door: the origin users actually reach in the browser, and the base the
# GitHub OAuth callback is built from. This is the WEB layer, not the backend port:
#   dev  -> http://localhost:3000  (the Nuxt dev server, which proxies /auth /api /mcp /trees)
#   prod -> https://your-domain    (nginx, which proxies the same paths)
# The session cookie is bound to this origin, so it must match where the browser is.
# Your GitHub OAuth app's callback must be ${PUBLIC_URL}/auth/github/callback.
PUBLIC_URL=http://localhost:3000

# Internal backend HTTP port (default 8722). The web layer proxies to it; users never
# hit it directly.
PORT=8722
